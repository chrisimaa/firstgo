# Copy to .env and fill in. .env is gitignored.
# Zoho CRM OAuth (self-client / server-based app)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# Google service account JSON, as a single-line string.
# Tip: GOOGLE_SERVICE_ACCOUNT_JSON=$(cat google-service-account.json)
GOOGLE_SERVICE_ACCOUNT_JSON=
